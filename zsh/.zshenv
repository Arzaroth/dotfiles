# Locale
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8

# WSL ssh-agent forwarding
[[ -n "${WSL_AUTH_SOCK}" ]] && export SSH_AUTH_SOCK="${WSL_AUTH_SOCK}"
